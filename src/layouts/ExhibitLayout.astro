---
const props = Astro.props.frontmatter ?? Astro.props;
const title = props.title ?? "CSARCH2 Virtual Exhibit";
const author = props.author ?? "Group 4";
const hideHeader = props.hideHeader ?? false;

// Font and Reset Imports
import 'normalize.css';
import '@fontsource-variable/montserrat';
import '@fontsource-variable/lora';
import '@fontsource-variable/noto-sans';
import '@fontsource/press-start-2p';
import '@fontsource/orbitron';

// Import your custom global styles (adjust path based on your folder structure)
import '../styles/global.css'; 
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} - CSARCH2 Virtual Exhibit</title>
    </head>

    <body>
        {!hideHeader && (
            <header class="header">
                <div class="header__titleblock">
                    <strong>{title}</strong>
                    <span class="header__subtitle">by {author}</span>
                </div>
            </header>
        )}

        <main class="content">
            <article class="article">
                <slot />
            </article>
        </main>

        <script is:inline>
            if (window.location.pathname !== "/") {
                localStorage.setItem("bus-last-page", window.location.pathname);
            }
        </script>

        <footer>CSARCH2 Virtual Exhibit &mdash; "Computer Architecture is Forever"</footer>
    </body>
</html>
